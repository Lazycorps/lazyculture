datasource db {
    provider          = "postgresql"
    url               = env("DATABASE_URL")
    directUrl         = env("DIRECT_URL")
    // shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-1.0.x", "debian-openssl-3.0.x"]
}

model User {
    id                     String                   @id
    name                   String
    slug                   String
    createDate             DateTime                 @default(now())
    updateDate             DateTime                 @default(now())
    admin                  Boolean                  @default(false)
    Response               QuestionResponse[]
    UserProgress           UserProgress?
    Reporting              QuestionReporting[]
    QuestionSeriesResponse QuestionSeriesResponse[]
    UserAchievement        UserAchievement[]
    BattleRoyalePlayer     BattleRoyalePlayer[]
    BattleRoyaleRank       BattleRoyaleRank?
    ShowdownPlayer         ShowdownPlayer[]
    ShowdownRank           ShowdownRank?
    AdventureProgress      UserAdventureProgress[]
    PushSubscription       PushSubscription[]
    Following              Follow[]                 @relation("UserFollowing")
    Followers              Follow[]                 @relation("UserFollowers")
    FollowNotifSent        FollowNotification[]     @relation("FollowNotifFollower")
    FollowNotifReceived    FollowNotification[]     @relation("FollowNotifFollowing")
    notifications          Notification[]
    BrainrunRun            BrainrunRun[]
    BrainrunMetaProgress   BrainrunMetaProgress?
    equippedAvatarId       Int?
    equippedAvatar         Avatar?                  @relation("EquippedAvatar", fields: [equippedAvatarId], references: [id], onDelete: SetNull)
    equippedFrameId        Int?
    equippedFrame          AvatarFrame?             @relation("EquippedFrame", fields: [equippedFrameId], references: [id], onDelete: SetNull)
    Wallet                 UserWallet?
    UserAvatar             UserAvatar[]
    UserAvatarFrame        UserAvatarFrame[]
}

// Porte-monnaie global (pièces) : monnaie transverse à tous les modes de jeu,
// indépendante du gold et des Points de Savoir de Brainrun
model UserWallet {
    userId      String   @id
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    coins       Int      @default(0)
    totalEarned Int      @default(0) // cumul des gains, jamais décrémenté
    createDate  DateTime @default(now())
    updateDate  DateTime @default(now()) @updatedAt
}

model Avatar {
    id            Int          @id @default(autoincrement())
    name          String
    imageUrl      String
    unlockType    String       @default("FREE") // FREE | COINS | ACHIEVEMENT
    price         Int          @default(0)
    achievementId Int?
    achievement   Achievement? @relation(fields: [achievementId], references: [id])
    enabled       Boolean      @default(true)
    sortOrder     Int          @default(0)
    createDate    DateTime     @default(now())
    updateDate    DateTime     @default(now()) @updatedAt
    owners        UserAvatar[]
    equippedBy    User[]       @relation("EquippedAvatar")
}

// Cadre décoratif : styleKey référence une clé de shared/avatarFrames.ts (effet CSS)
model AvatarFrame {
    id            Int               @id @default(autoincrement())
    name          String
    styleKey      String            @unique
    unlockType    String            @default("FREE") // FREE | COINS | ACHIEVEMENT
    price         Int               @default(0)
    achievementId Int?
    achievement   Achievement?      @relation(fields: [achievementId], references: [id])
    enabled       Boolean           @default(true)
    sortOrder     Int               @default(0)
    createDate    DateTime          @default(now())
    updateDate    DateTime          @default(now()) @updatedAt
    owners        UserAvatarFrame[]
    equippedBy    User[]            @relation("EquippedFrame")
}

model UserAvatar {
    id         Int      @id @default(autoincrement())
    userId     String
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    avatarId   Int
    avatar     Avatar   @relation(fields: [avatarId], references: [id], onDelete: Cascade)
    unlockedAt DateTime @default(now())

    @@unique([userId, avatarId])
}

model UserAvatarFrame {
    id         Int         @id @default(autoincrement())
    userId     String
    user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    frameId    Int
    frame      AvatarFrame @relation(fields: [frameId], references: [id], onDelete: Cascade)
    unlockedAt DateTime    @default(now())

    @@unique([userId, frameId])
}

model Follow {
    followerId  String
    follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
    followingId String
    following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
    createDate  DateTime @default(now())

    @@id([followerId, followingId])
    @@index([followingId])
}

// Trace de la dernière notification "nouvel abonné" par paire, conservée après
// un unfollow pour empêcher le spam via des cycles follow/unfollow répétés
model FollowNotification {
    followerId  String
    follower    User     @relation("FollowNotifFollower", fields: [followerId], references: [id], onDelete: Cascade)
    followingId String
    following   User     @relation("FollowNotifFollowing", fields: [followingId], references: [id], onDelete: Cascade)
    sentDate    DateTime @default(now())

    @@id([followerId, followingId])
}

model UserProgress {
    userId     String   @id
    user       User     @relation(fields: [userId], references: [id])
    xp         Int
    levelId    Int
    level      Level    @relation(fields: [levelId], references: [id])
    createDate DateTime @default(now())
    updateDate DateTime @default(now())
}

model Level {
    id           Int            @id
    name         String
    xp_threshold Int
    createDate   DateTime       @default(now())
    updateDate   DateTime       @default(now())
    UserProgress UserProgress[]
}

model Question {
    id         Int                 @id @default(autoincrement())
    difficulty Int
    data       Json?
    picture    String              @default("")
    source     String
    language   String
    xp_earned  Int                 @default(10)
    createDate DateTime            @default(now())
    updateDate DateTime            @default(now())
    userCreate String
    userUpdate String
    deleted    Boolean             @default(false)
    Response   QuestionResponse[]
    Reporting  QuestionReporting[] @relation("QuestionToReporting")
}

model QuestionResponse {
    id         Int      @id @default(autoincrement())
    userId     String
    user       User     @relation(fields: [userId], references: [id])
    questionId Int
    question   Question @relation(fields: [questionId], references: [id])
    success    Boolean
    date       DateTime @default(now())
}

model QuestionTheme {
    id           Int      @id @default(autoincrement())
    name         String
    slug         String
    picture      String   @default("")
    battleRoyale Boolean  @default(true)
    createDate   DateTime @default(now())
    updateDate   DateTime @default(now())
    userCreate   String
    userUpdate   String
}

model QuestionReporting {
    id          Int      @id @default(autoincrement())
    userId      String
    user        User     @relation(fields: [userId], references: [id])
    questionId  Int
    question    Question @relation("QuestionToReporting", fields: [questionId], references: [id])
    commentaire String
    date        DateTime @default(now())
    closed      Boolean
}

model QuestionSeries {
    id                     Int                      @id @default(autoincrement())
    type                   String
    difficulty             Int
    title                  String
    data                   Json?
    date                   DateTime                 @db.Date
    createDate             DateTime                 @default(now())
    updateDate             DateTime                 @default(now())
    userCreate             String
    userUpdate             String
    QuestionSeriesResponse QuestionSeriesResponse[]
}

model QuestionSeriesResponse {
    id         Int            @id @default(autoincrement())
    seriesId   Int
    series     QuestionSeries @relation(fields: [seriesId], references: [id])
    userId     String
    user       User           @relation(fields: [userId], references: [id])
    seriesType String         @default("")
    result     Decimal        @default(0)
    data       Json?
    createDate DateTime       @default(now())
    updateDate DateTime       @default(now())
}

model Achievement {
    id             Int               @id @default(autoincrement())
    title          String
    description    String
    createdAt      DateTime          @default(now())
    conditionType  String
    conditionValue Int
    xpEarned       Int
    icon           String            @default("")
    hidden         Boolean           @default(false)
    users          UserAchievement[]
    avatars        Avatar[]
    avatarFrames   AvatarFrame[]
}

model UserAchievement {
    id            Int         @id @default(autoincrement())
    userId        String
    user          User        @relation(fields: [userId], references: [id])
    achievementId Int
    achievement   Achievement @relation(fields: [achievementId], references: [id])
    unlockedAt    DateTime    @default(now())

    @@unique([userId, achievementId])
}

model BattleRoyaleMatch {
    id                      String               @id @default(uuid())
    status                  String               @default("WAITING") // WAITING, PLAYING, FINISHED
    currentRound            Int                  @default(0)
    currentQuestionId       Int?
    currentQuestionStart    DateTime?
    currentQuestionDuration Int?                 // Durée en secondes
    winnerId                String?
    createdAt               DateTime             @default(now())
    players                 BattleRoyalePlayer[]
}

model BattleRoyalePlayer {
    id                 String            @id @default(uuid())
    matchId            String
    match              BattleRoyaleMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
    userId             String
    user               User              @relation(fields: [userId], references: [id])
    lives              Int               @default(3)
    lastAnsweredRound  Int               @default(-1)
    lastAnswerCorrect  Boolean?
    lastAnswerTime     DateTime?
    eliminatedAtRound  Int?
    xpEarned           Int               @default(0)
    joinedAt           DateTime          @default(now())

    @@unique([matchId, userId])
}

model BattleRoyaleRank {
    userId      String   @id
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    points      Int      @default(0)
    wins        Int      @default(0)
    gamesPlayed Int      @default(0)
    createDate  DateTime @default(now())
    updateDate  DateTime @default(now())
}

model ShowdownMatch {
    id                      String               @id @default(uuid())
    status                  String               @default("WAITING") // WAITING, THEME_SELECTION, PLAYING, FINISHED
    currentRound            Int                  @default(0)
    currentQuestionId       Int?
    currentQuestionStart    DateTime?
    currentQuestionDuration Int?
    winnerId                String?
    createdAt               DateTime             @default(now())
    players                 ShowdownPlayer[]
}

model ShowdownPlayer {
    id                 String            @id @default(uuid())
    matchId            String
    match              ShowdownMatch     @relation(fields: [matchId], references: [id], onDelete: Cascade)
    userId             String
    user               User              @relation(fields: [userId], references: [id])
    hp                 Int               @default(100)
    xpEarned           Int               @default(0)
    joinedAt           DateTime          @default(now())
    teamId             String?           // Optionnel, pour de futurs modes 2v2/3v3

    @@unique([matchId, userId])
}

model ShowdownRank {
    userId      String   @id
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    points      Int      @default(0)
    wins        Int      @default(0)
    gamesPlayed Int      @default(0)
    createDate  DateTime @default(now())
    updateDate  DateTime @default(now())
}

model Adventure {
    id         Int                     @id @default(autoincrement())
    title      String
    themeSlug  String
    createDate DateTime                @default(now())
    updateDate DateTime                @default(now())
    stages     AdventureStage[]
    progresses UserAdventureProgress[]
}

model AdventureStage {
    id          Int       @id @default(autoincrement())
    adventureId Int
    adventure   Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
    sequence    Int       // 1, 2, 3...
    type        String    // "STEP", "CONTROL", "EXAM"
    title       String
    questionIds Int[]
}

model UserAdventureProgress {
    id          Int       @id @default(autoincrement())
    userId      String
    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    adventureId Int
    adventure   Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
    currentStage Int       @default(1)
    completed   Boolean   @default(false)
    stageScores Json?     @default("{}")
    updateDate  DateTime  @default(now())

    @@unique([userId, adventureId])
}

model BrainrunRun {
    id              String         @id @default(uuid())
    userId          String
    user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
    status          String         @default("IN_PROGRESS") // IN_PROGRESS, WON, LOST, ABANDONED
    currentAct      Int            @default(1) // 1..3
    currentRow      Int            @default(1) // 1..7, rangée où se trouve/choisit le joueur dans l'acte
    currentCol      Int? // colonne du nœud actif dans currentRow ; null tant que le joueur n'a pas choisi de nœud sur cette rangée
    healthPoint     Int
    maxHealthPoint  Int
    gold            Int            @default(0)
    usedQuestionIds Int[]          @default([]) // anti-répétition sur toute la run
    usedEnemyIds    String[]       @default([]) // ennemis déjà tirés dans l'acte en cours (shared/brainrunEnemies.ts), réinitialisé à chaque changement d'acte
    relics          String[]       @default([]) // ids de reliques passives possédées (shared/brainrunItems.ts)
    consumables     Json           @default("{}") // Record<consumableId, count>
    shieldArmed     Boolean        @default(false) // consommable Bouclier actif : annule la prochaine perte de PV
    bannedThemes    String[]       @default([]) // thèmes bannis par la relique Purge Thématique, exclus des pools ennemi/boss
    pendingThemeBanChoice Boolean  @default(false) // true entre l'octroi de Purge Thématique et le choix du thème par le joueur ; bloque acknowledgeRoom
    xpEarned        Int?
    knowledgePointsEarned Int? // Points de Savoir gagnés à la fin de cette run (or converti, cf. server/utils/brainrunMetaHelper.ts)
    coinsEarned     Int            @default(0) // Pièces (monnaie globale UserWallet) créditées cette run, uniquement aux Boss d'acte vaincus (cf. grantBrainrunActCoins)
    createDate      DateTime       @default(now())
    updateDate      DateTime       @default(now())
    endDate         DateTime?
    rooms           BrainrunRoom[]

    @@index([userId])
    @@index([userId, status])
}

model BrainrunRoom {
    id                  Int         @id @default(autoincrement())
    runId               String
    run                 BrainrunRun @relation(fields: [runId], references: [id], onDelete: Cascade)
    act                 Int // 1..3
    row                 Int // 1..7 dans l'acte
    col                 Int // position du nœud dans sa rangée (0-based)
    nextCols            Int[]       @default([]) // colonnes de la rangée row+1 accessibles depuis ce nœud ; vide pour le Boss (row 7)
    type                String // STANDARD, ELITE, BOSS, REST, SHOP, EVENT — assigné dès la génération de l'acte
    status              String      @default("PENDING") // PENDING, ACTIVE, CLEARED, FAILED, SKIPPED
    enemyId             String? // id du catalogue BRAINRUN_ENEMIES (shared/brainrunEnemies.ts), uniquement pour type=STANDARD/ELITE
    questionIds         Int[]       @default([])
    responses           Json?
    goldEarned          Int         @default(0)
    bossId              String? // id du catalogue BRAINRUN_BOSSES (shared/brainrunBosses.ts), uniquement pour type=BOSS
    bossHealthPoint     Int? // PV courants du boss, uniquement pour type=BOSS
    bossMaxHealthPoint  Int? // PV max du boss au démarrage du combat, uniquement pour type=BOSS
    bossPhase           Int         @default(0) // nombre de résurrections consommées (malus "phoenix_revive" uniquement)
    questionStartedAt   DateTime? // horodatage d'affichage de la question en attente, sert de base au chrono du combat de boss
    offers              Json? // BrainrunOffer[] — bonus post-combat (ELITE/BOSS) ou offres de la Boutique
    offersRequireChoice Boolean     @default(false) // true seulement pour le bonus post-combat : bloque acknowledgeRoom tant que non résolu
    offersResolved      Boolean     @default(false)
    eventId             String? // clé dans le catalogue BRAINRUN_EVENTS (shared/brainrunItems.ts)
    consumableReveal    Json? // { eliminatedIds?: number[]; hintId?: number } — effet 50/50 / Appel à un ami sur la question en cours
    createDate          DateTime    @default(now())
    updateDate          DateTime    @default(now())

    @@unique([runId, act, row, col])
    @@index([runId])
}

model BrainrunMetaProgress {
    userId                String    @id
    user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    knowledgePoints       Int       @default(0)
    unlockedTalents       String[]  @default([]) // ids du catalogue BRAINRUN_TALENTS (shared/brainrunTalents.ts)
    discoveredRelics      String[]  @default([]) // ids de reliques obtenues au moins une fois, toutes runs confondues (glossaire, shared/brainrunItems.ts)
    discoveredConsumables String[]  @default([]) // idem pour les consommables
    coinsEarnedToday      Int       @default(0) // pièces gagnées via les paliers d'acte Brainrun le jour de coinsEarnedDate (plafond BRAINRUN_DAILY_COIN_CAP)
    coinsEarnedDate       DateTime? @db.Date // jour (heure locale serveur, même convention que le Daily) du dernier gain compté dans coinsEarnedToday ; null avant le premier gain
    createDate            DateTime  @default(now())
    updateDate            DateTime  @default(now())
}

model PushSubscription {
    id         String   @id @default(uuid())
    userId     String
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    endpoint   String   @unique
    p256dh     String
    auth       String
    createDate DateTime @default(now())
}

model Notification {
    id         String   @id @default(uuid())
    userId     String
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    title      String
    body       String
    url        String?
    read       Boolean  @default(false)
    createDate DateTime @default(now())
    metadata   Json?

    @@index([userId])
    @@index([read])
}

